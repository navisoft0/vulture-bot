# Copy to vulture_cred.env and fill in. Never commit the real file.

# --- Claude API ---
ANTHROPIC_API_KEY=

# --- Massive (market data, free Basic plan: https://massive.com) ---
MASSIVE_API_KEY=

# --- Reddit (praw) ---
CLIENT_ID=
CLIENT_SECRET=
USER_AGENT=vulture-bot/2.0 by u/yourname

# --- Discord webhooks ---
DISCORD_WEBHOOK_FORUM=            # forum channel webhook: scored plays
DISCORD_WEBHOOK_NEWS=             # regular channel webhook: Cramer Watch digest
DISCORD_TAG_ID_LOW=               # optional forum tag ids
DISCORD_TAG_ID_MEDIUM=
DISCORD_TAG_ID_HIGH=

# --- Google Sheets ---
GOOGLE_CREDENTIALS_JSON=          # service-account JSON, single line
GOOGLE_SHEET_NAME=                # spreadsheet name; tabs: "Vulture Data", "Processed", "Cramer Watch"

# --- Tunables (defaults shown) ---
#POST_THRESHOLD=7.0
#HIGH_TAG_THRESHOLD=8.5
#MEDIUM_TAG_THRESHOLD=7.5
#MAX_POSTS_PER_SCAN=40
#STOCKTWITS_ENABLED=true
#STATE_BACKEND=file               # "sheet" for hosts with ephemeral disks
#TARGET_SUBREDDITS=wallstreetbets,shortsqueeze,WallStreetbetsELITE,smallstreetbets
#LOG_LEVEL=INFO

# --- Anthropic cost controls (defaults shown) ---
#BATCH_SCORING=true               # Batches API: 50% cheaper, adds minutes of latency
#BATCH_TIMEOUT_S=1800
#VULTURE_MODEL=claude-opus-4-8    # scoring model; claude-sonnet-5 ~60% cheaper,
                                  # claude-haiku-4-5 ~80% cheaper
#VULTURE_EFFORT=                  # low|medium|high|xhigh|max; set low if using sonnet-5
#VULTURE_CRAMER_MODEL=claude-haiku-4-5
